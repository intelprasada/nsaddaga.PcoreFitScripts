#!/usr/bin/env bash
# bin/supercsv – thin entry-point wrapper for supercsv
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

export PYTHONPATH="${REPO_ROOT}/lib/python${PYTHONPATH:+:${PYTHONPATH}}"

exec python3 "${REPO_ROOT}/tools/supercsv/supercsv.py" "$@"
