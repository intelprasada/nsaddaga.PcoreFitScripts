#!/usr/bin/env bash
# bin/supertracker – thin entry-point wrapper for supertracker
# supertracker imports supercsv + shared widgets, so we add tools/supercsv/
# to PYTHONPATH so those modules are found without duplicating files.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

export PYTHONPATH="${REPO_ROOT}/lib/python:${REPO_ROOT}/tools/supercsv${PYTHONPATH:+:${PYTHONPATH}}"

exec python3 "${REPO_ROOT}/tools/supertracker/supertracker.py" "$@"
