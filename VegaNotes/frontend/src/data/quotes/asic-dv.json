[
  { "id": "ruskin-quality",       "text": "Quality is never an accident; it is always the result of intelligent effort.",                                       "attribution": "John Ruskin",          "culture": "Engineering Wisdom" },
  { "id": "dijkstra-presence",    "text": "Testing shows the presence, not the absence of bugs.",                                                                "attribution": "Edsger W. Dijkstra",   "culture": "Engineering Wisdom" },
  { "id": "knuth-proven",         "text": "Beware of bugs in the above code; I have only proved it correct, not tried it.",                                      "attribution": "Donald Knuth",         "culture": "Engineering Wisdom" },
  { "id": "hoare-simple",         "text": "There are two ways of constructing a design: make it so simple that there are obviously no deficiencies, or make it so complicated that there are no obvious deficiencies.", "attribution": "C.A.R. Hoare", "culture": "Engineering Wisdom" },
  { "id": "ford-quality",         "text": "Quality means doing it right when no one is looking.",                                                                "attribution": "Henry Ford",           "culture": "Engineering Wisdom" },
  { "id": "dijkstra-debug",       "text": "If debugging is the process of removing bugs, then programming must be the process of putting them in.",              "attribution": "Edsger W. Dijkstra",   "culture": "Engineering Wisdom" },
  { "id": "verif-assumption",     "text": "It is not the bug that is hard to find; it is the assumption hiding it.",                                             "attribution": "Verification proverb", "culture": "ASIC Verification" },
  { "id": "verif-coverage",       "text": "Coverage is a question, not an answer.",                                                                              "attribution": "Verification proverb", "culture": "ASIC Verification" },
  { "id": "verif-shift-left",     "text": "A bug found in simulation costs a dollar; in silicon, a million.",                                                    "attribution": "ASIC engineering lore", "culture": "ASIC Verification" },
  { "id": "franklin-prevention",  "text": "An ounce of prevention is worth a pound of cure.",                                                                    "attribution": "Benjamin Franklin",    "culture": "Quality" },
  { "id": "ru-trust-verify",      "text": "Trust, but verify.",                                                                                                  "attribution": "Russian proverb",      "culture": "Quality",                  "original": "Доверяй, но проверяй" },
  { "id": "deming-quality",       "text": "Quality is everyone's responsibility.",                                                                               "attribution": "W. Edwards Deming",    "culture": "Quality" },
  { "id": "knuth-premature",      "text": "Premature optimization is the root of all evil.",                                                                     "attribution": "Donald Knuth",         "culture": "Productivity" },
  { "id": "beck-three-steps",     "text": "Make it work, make it right, make it fast.",                                                                          "attribution": "Kent Beck",            "culture": "Productivity" },
  { "id": "weeks-coding",         "text": "Weeks of coding can save you hours of planning.",                                                                     "attribution": "Engineering proverb",  "culture": "Productivity" },
  { "id": "johnson-first-solve",  "text": "First, solve the problem. Then, write the code.",                                                                     "attribution": "John Johnson",         "culture": "Productivity" },
  { "id": "davinci-simplicity",   "text": "Simplicity is the ultimate sophistication.",                                                                          "attribution": "Leonardo da Vinci",    "culture": "Productivity" },
  { "id": "kelvin-measure",       "text": "If you cannot measure it, you cannot improve it.",                                                                    "attribution": "Lord Kelvin",          "culture": "Productivity" },
  { "id": "ike-planning",         "text": "Plans are nothing; planning is everything.",                                                                          "attribution": "Dwight D. Eisenhower", "culture": "Project Execution" },
  { "id": "shaw-comm-illusion",   "text": "The single biggest problem in communication is the illusion that it has taken place.",                                "attribution": "George Bernard Shaw",  "culture": "Communication" },
  { "id": "brooks-mmm",           "text": "Adding manpower to a late project makes it later.",                                                                   "attribution": "Fred Brooks",          "culture": "Project Execution" },
  { "id": "ford-together",        "text": "Coming together is a beginning; keeping together is progress; working together is success.",                          "attribution": "Henry Ford",           "culture": "Teamwork" },
  { "id": "abelson-readable",     "text": "Programs must be written for people to read, and only incidentally for machines to execute.",                         "attribution": "Harold Abelson",       "culture": "Communication" },
  { "id": "ardis-onepage",        "text": "A specification that will not fit on one page cannot be understood.",                                                 "attribution": "Mark Ardis",           "culture": "Communication" },
  { "id": "drucker-measured",     "text": "What gets measured gets managed.",                                                                                    "attribution": "Peter Drucker",        "culture": "Project Execution" },
  { "id": "berard-spec-frozen",   "text": "Walking on water and developing from a specification are easy — if both are frozen.",                                 "attribution": "Edward V. Berard",     "culture": "Project Execution" },
  { "id": "hopper-always-done",   "text": "The most damaging phrase in the language is: 'We've always done it this way.'",                                       "attribution": "Grace Hopper",         "culture": "Engineering Wisdom" },
  { "id": "wooden-time-redo",     "text": "If you don't have time to do it right, when will you have time to do it over?",                                       "attribution": "John Wooden",          "culture": "Quality" },
  { "id": "verif-regression",     "text": "A green regression is the engineer's morning coffee.",                                                                "attribution": "Verification proverb", "culture": "ASIC Verification" },
  { "id": "verif-corner",         "text": "The corner cases are where the design lives or dies.",                                                                "attribution": "Verification proverb", "culture": "ASIC Verification" }
]
